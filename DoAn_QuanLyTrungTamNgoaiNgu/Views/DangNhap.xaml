<Window x:Class="DoAn_QuanLyTrungTamNgoaiNgu.Views.DangNhap"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DoAn_QuanLyTrungTamNgoaiNgu.ViewModels"
        Title="Đăng nhập — Trung tâm Ngoại ngữ"
        Height="520" Width="860"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.DataContext>
        <vm:DangNhapViewModel/>
    </Window.DataContext>

    <Window.Resources>

        <Color x:Key="PrimaryColor">#1E6FB5</Color>
        <Color x:Key="PrimaryDark">#155999</Color>
        <Color x:Key="AccentColor">#F0F7FF</Color>
        <SolidColorBrush x:Key="PrimaryBrush"    Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDark}"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="TextPrimary"     Color="#1A1A2E"/>
        <SolidColorBrush x:Key="TextSecondary"   Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderLight"     Color="#E5E7EB"/>
        <SolidColorBrush x:Key="ErrorBrush"      Color="#DC2626"/>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnDangNhap" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16"
            Background="White">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                              Color="#000000" Opacity="0.15"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="16,0,0,16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E6FB5" Offset="0"/>
                        <GradientStop Color="#0D4A8A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" Margin="40,0">

                    <Border Width="72" Height="72" CornerRadius="20"
                            Background="#FFFFFF22"
                            HorizontalAlignment="Left" Margin="0,0,0,24">
                        <TextBlock Text="🎓" FontSize="36"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Trung tâm" FontSize="14"
                               Foreground="#AACCEE" FontWeight="Medium"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Ngoại ngữ" FontSize="28"
                               Foreground="White" FontWeight="Bold"
                               LineHeight="34"/>
                    <TextBlock Text="English Center" FontSize="13"
                               Foreground="#88BBDD" Margin="0,6,0,0"/>
                    <Rectangle Height="1" Fill="#FFFFFF30" Margin="0,32,0,32"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12.5"
                               Foreground="#99CCEE" LineHeight="20">
                        Hệ thống quản lý học viên,&#x0a;lớp học, điểm danh và học phí&#x0a;dành cho nhân viên nội bộ.
                    </TextBlock>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="50,0,50,0">
                <StackPanel VerticalAlignment="Center">

                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,-120,0,0"
                            Width="32" Height="32"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondary}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnDong_Click"/>

                    <TextBlock Text="Chào mừng trở lại"
                               FontSize="11" FontWeight="Medium"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Đăng nhập"
                               FontSize="28" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="Nhập thông tin tài khoản để tiếp tục"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="0,0,0,36"/>

                    <TextBlock Text="Tên đăng nhập" FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <TextBox Style="{StaticResource InputStyle}"
                             Text="{Binding TenDangNhap, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,20"/>

                    <TextBlock Text="Mật khẩu" FontSize="13"
                               FontWeight="Medium"
                               Foreground="{StaticResource TextPrimary}"
                               Margin="0,0,0,8"/>
                    <PasswordBox x:Name="pbMatKhau"
                                 Style="{StaticResource PasswordStyle}"
                                 Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding ThongBaoLoi}"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12.5"
                               Margin="0,0,0,20"
                               Visibility="{Binding ThongBaoLoi,
                                   Converter={StaticResource StringToVisibilityConverter}}"/>

                    <Button Content="Đăng nhập"
                            Style="{StaticResource BtnDangNhap}"
                            Command="{Binding DangNhapCommand}"
                            CommandParameter="{Binding ElementName=pbMatKhau}"/>

                    <TextBlock Margin="0,24,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}">
                        <Run>Tài khoản mẫu:</Run>
                        <Run Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold">admin / 123</Run>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
