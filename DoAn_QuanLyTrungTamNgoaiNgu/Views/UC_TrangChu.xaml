<UserControl x:Class="DoAn_QuanLyTrungTamNgoaiNgu.Views.UC_TrangChu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
       
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                      Color="#000000" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0"
                                      Color="#000000" Opacity="0.05"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">

            <StackPanel Margin="0,0,0,28">
                <TextBlock x:Name="tbChao"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#1A1A2E"/>
                <TextBlock Text="Đây là tổng quan hệ thống hôm nay."
                           FontSize="13.5" Foreground="#6B7280"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <TextBlock Text="THỐNG KÊ NHANH" FontSize="11"
                       FontWeight="SemiBold" Foreground="#9CA3AF"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="4" Margin="0,0,0,28">
                
                <Border Style="{StaticResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DBEAFE" Offset="0"/>
                                    <GradientStop Color="#BFDBFE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👨‍🎓" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Học viên" FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="—" FontSize="28"
                                   FontWeight="Bold" Foreground="#1E6FB5"
                                   x:Name="tbSoHocVien"/>
                        <TextBlock Text="đang học" FontSize="11"
                                   Foreground="#10B981"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#D1FAE5" Offset="0"/>
                                    <GradientStop Color="#A7F3D0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="📚" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Lớp đang mở" FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="—" FontSize="28"
                                   FontWeight="Bold" Foreground="#059669"
                                   x:Name="tbSoLop"/>
                        <TextBlock Text="lớp học" FontSize="11"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}" Margin="0,0,14,0">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FEF3C7" Offset="0"/>
                                    <GradientStop Color="#FDE68A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💰" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Học phí tháng này" FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="—" FontSize="22"
                                   FontWeight="Bold" Foreground="#D97706"
                                   x:Name="tbDoanhThu"/>
                        <TextBlock Text="VNĐ" FontSize="11"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCard}">
                    <StackPanel>
                        <Border Width="40" Height="40" CornerRadius="10"
                                HorizontalAlignment="Left" Margin="0,0,0,14">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FCE7F3" Offset="0"/>
                                    <GradientStop Color="#FBCFE8" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="👩‍🏫" FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Giáo viên" FontSize="12"
                                   Foreground="#6B7280"/>
                        <TextBlock Text="—" FontSize="28"
                                   FontWeight="Bold" Foreground="#DB2777"
                                   x:Name="tbSoGiaoVien"/>
                        <TextBlock Text="đang dạy" FontSize="11"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="TRUY CẬP NHANH" FontSize="11"
                       FontWeight="SemiBold" Foreground="#9CA3AF"
                       Margin="0,0,0,14"/>

            <UniformGrid Columns="3" Margin="0,0,0,28">
                <Border Style="{StaticResource QuickCard}" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📝" FontSize="24" Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Đăng ký học viên" FontSize="13.5"
                                       FontWeight="SemiBold" Foreground="#1A1A2E"/>
                            <TextBlock Text="Thêm học viên vào lớp"
                                       FontSize="12" Foreground="#9CA3AF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource QuickCard}" Margin="0,0,14,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅" FontSize="24" Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Điểm danh hôm nay" FontSize="13.5"
                                       FontWeight="SemiBold" Foreground="#1A1A2E"/>
                            <TextBlock Text="Ghi nhận buổi học"
                                       FontSize="12" Foreground="#9CA3AF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource QuickCard}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💳" FontSize="24" Margin="0,0,14,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Thu học phí" FontSize="13.5"
                                       FontWeight="SemiBold" Foreground="#1A1A2E"/>
                            <TextBlock Text="Lập phiếu thu"
                                       FontSize="12" Foreground="#9CA3AF"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Text="LỊCH HỌC HÔM NAY" FontSize="11"
                       FontWeight="SemiBold" Foreground="#9CA3AF"
                       Margin="0,0,0,14"/>
            <Border Background="White" CornerRadius="12" Padding="24,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0"
                                      Color="#000000" Opacity="0.05"/>
                </Border.Effect>
                <StackPanel>
                   
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Lớp" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="1" Text="Khóa học" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="2" Text="Ca học" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="3" Text="Phòng" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#9CA3AF"/>
                        <TextBlock Grid.Column="4" Text="Giáo viên" FontSize="12"
                                   FontWeight="SemiBold" Foreground="#9CA3AF"/>
                    </Grid>
                    <Rectangle Height="1" Fill="#F3F4F6" Margin="0,0,0,10"/>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="IELTS Cơ bản A1"
                                   FontSize="13.5" FontWeight="Medium"
                                   Foreground="#1A1A2E"/>
                        <TextBlock Grid.Column="1" Text="IELTS Foundation"
                                   FontSize="13" Foreground="#6B7280"/>
                        <Border Grid.Column="2"
                                Background="#DBEAFE" CornerRadius="6"
                                Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock Text="Ca 1" FontSize="12"
                                       Foreground="#1E6FB5" FontWeight="Medium"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="P.101"
                                   FontSize="13" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="4" Text="Cô Duyên"
                                   FontSize="13" Foreground="#6B7280"/>
                    </Grid>

                    <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TOEIC 600+ B2"
                                   FontSize="13.5" FontWeight="Medium"
                                   Foreground="#1A1A2E"/>
                        <TextBlock Grid.Column="1" Text="TOEIC Advanced"
                                   FontSize="13" Foreground="#6B7280"/>
                        <Border Grid.Column="2"
                                Background="#D1FAE5" CornerRadius="6"
                                Padding="8,3" HorizontalAlignment="Left">
                            <TextBlock Text="Ca 2" FontSize="12"
                                       Foreground="#059669" FontWeight="Medium"/>
                        </Border>
                        <TextBlock Grid.Column="3" Text="P.203"
                                   FontSize="13" Foreground="#6B7280"/>
                        <TextBlock Grid.Column="4" Text="Thầy Quân"
                                   FontSize="13" Foreground="#6B7280"/>
                    </Grid>

                    <TextBlock Text="* Dữ liệu lịch học sẽ được load từ database sau khi kết nối."
                               FontSize="11.5" Foreground="#D1D5DB"
                               Margin="0,14,0,0" FontStyle="Italic"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
